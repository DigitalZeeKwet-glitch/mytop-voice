# Port to listen on (Render.com automatically provides PORT)
PORT=3000

# PostgreSQL Connection String (Optional, falls back to MemoryDB if not provided)
DATABASE_URL=postgresql://username:password@localhost:5432/mytop_voice

# JWT Secret for Admin Sessions
JWT_SECRET=use_a_strong_secret_key_here

# Admin Login Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=strong_admin_password_here

# JSON string of VIP Users and their expiration dates (format: YYYY-MM-DD)
# Used as seed/fallback if the database is empty or not configured.
VIP_USERS={"000123":"2026-12-15","another_key":"2025-08-31"}
